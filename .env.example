# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
# Get a free database from Neon (https://neon.tech) or Supabase (https://supabase.com)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add your Vercel domain to Authorized JavaScript Origins and:
# Add https://your-app.vercel.app/api/auth/google/callback to Authorized redirect URIs
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Session ───────────────────────────────────────────────────────────────────
# A long random string for signing session cookies
SESSION_SECRET=change-this-to-a-long-random-secret

# ── AI / OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get a free API key at https://resend.com
RESEND_API_KEY=re_...

# ── Object Storage ────────────────────────────────────────────────────────────
# Only needed if using file upload features
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=
# PRIVATE_OBJECT_DIR=
# PUBLIC_OBJECT_SEARCH_PATHS=
